using System.Diagnostics;
using Microsoft.AspNetCore.Mvc;
using basic.Models;
using Microsoft.Extensions.FileSystemGlobbing;

namespace basic.Controllers;

public class CourseController : Controller
{
    

    public IActionResult Index()
    {
        var kurs=new Course();
        kurs.Id=1;
        kurs.Title="aspnetcore kursu";
        kurs.Description="";
        kurs.Image="indir.png";
        return View(kurs);
    }

    public IActionResult List()
    {
        var kurslar= new List<Course>()
        {
            new Course() {Id=1,Title="aspnetcore",Description="",Image="indir.png"},
            new Course() {Id=2,Title="java",Description="",Image="java.png"},
            new Course() {Id=3,Title="c#",Description="",Image="c#.png"},
            new Course() {Id=4,Title="react",Description="",Image="react.png"}

        };
        return View("CourseList",kurslar);
    }
    

    
}
